# Ignore the config file that contains sensitive information
# Ignore node_modules directory
node_modules/

# Runtime state — contains sensitive credentials (playerToken, playerId, server IP)
# Auto-recreated on startup if missing
Core/data/app-state.json
Core/data/app-state.og.json
# Contains the Steam auth token obtained during registration, which is sensitive information and allows access to the Rust+ API for a user.
Core/data/steam-auth-token.json

# RustPlus auth config — contains FCM credentials, auth token, and push token
rustplus.config.json
rustplus.config.og.json

# Proto decode error log — local debug artifact, not for source control
proto-decode-errors.jsonl

#ignore log files
logs/

#ignore environment variable files that may contain sensitive information
.env
.env.local
.env.dev

#ignore agent stuff
AGENTS.md
docs/AI_AGENT_CONTEXT_MASTER.md
docs/AI_AGENT_CONTEXT_UPDATE.md
ProjectReq.md

.continue/